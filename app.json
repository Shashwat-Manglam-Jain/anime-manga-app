{
  "expo": {
    "name": "SmjStreamz",
    "slug": "anime-manga-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.smj.streamz",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      }
    },
    "extra": {
      "eas": {
        "projectId": "915c6f2f-801c-4ce5-9531-18a65899ddf7"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 1284,
          "resizeMode": "cover",
          "backgroundColor": "#0a0a0f"
        }
      ]
    ]
  }
}
